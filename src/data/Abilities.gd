static func get_ability(id: String) -> Dictionary:
	return DATA.get(id, {"base_damage": 10, "max_charges": -1, "cooldown_turns": 0, "range": 1})

static func all_ids() -> Array[String]:
	var ids: Array[String] = []
	for k: String in DATA.keys():
		ids.append(k)
	return ids

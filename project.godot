; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format is still documented here:
; https://docs.godotengine.org/en/stable/tutorials/misc/configuration_file.html

config_version=5

[application]

config/name="Descent"
config/description="Turn-based tactical dungeon crawler (DCC-style)"
config/features=PackedStringArray("4.3", "Forward Plus")
run/main_scene="res://scenes/Main.tscn"
config/icon="res://icon.svg"

[autoload]

GameRng="*res://scripts/GameRng.gd"
System="*res://scripts/System.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true

[rendering]

renderer/rendering_method="forward_plus"
